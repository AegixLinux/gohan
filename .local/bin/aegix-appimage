#!/usr/bin/env bash
# Aegix AppImage Manager
# Automatically discovers AppImages and creates desktop entries
# Usage: aegix-appimage [scan|add|remove|list|clean]

set -euo pipefail

# Configuration
APPIMAGE_DIRS=(
    "$HOME/Applications"
    "$HOME/.local/share/AppImages"
    "$HOME/AppImages"
    "$HOME/apps"
)
DESKTOP_DIR="$HOME/.local/share/applications"
ICON_DIR="$HOME/.local/share/icons/hicolor/256x256/apps"
REGISTRY_FILE="$HOME/.config/aegix/appimages.json"
REGISTRY_DIR="$(dirname "$REGISTRY_FILE")"

# Ensure directories exist
mkdir -p "$DESKTOP_DIR" "$ICON_DIR" "$REGISTRY_DIR"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Extract icon from AppImage if possible
extract_icon() {
    local appimage="$1"
    local icon_path="$2"

    # Try to extract .DirIcon from AppImage
    if command -v 7z >/dev/null 2>&1; then
        # Use 7z to extract .DirIcon if it exists
        7z e -o"$(dirname "$icon_path")" "$appimage" .DirIcon -y >/dev/null 2>&1 && {
            mv "$(dirname "$icon_path")/.DirIcon" "$icon_path" 2>/dev/null || true
            return 0
        }
    fi

    # Try using AppImage itself to extract icon
    if [[ -x "$appimage" ]]; then
        "$appimage" --appimage-extract "*.desktop" >/dev/null 2>&1 || true
        "$appimage" --appimage-extract "*.png" >/dev/null 2>&1 || true
        "$appimage" --appimage-extract "*.svg" >/dev/null 2>&1 || true

        # Find extracted icon
        if [[ -d "squashfs-root" ]]; then
            local icon_file=$(find squashfs-root -name "*.png" -o -name "*.svg" 2>/dev/null | head -1)
            if [[ -n "$icon_file" ]]; then
                cp "$icon_file" "$icon_path" 2>/dev/null || true
                rm -rf squashfs-root
                return 0
            fi
            rm -rf squashfs-root
        fi
    fi

    return 1
}

# Generate desktop file for AppImage
generate_desktop_file() {
    local appimage_path="$1"
    local name="$2"
    local desktop_file="$3"
    local icon_path="$4"

    # Make sure AppImage is executable
    chmod +x "$appimage_path" 2>/dev/null || true

    # Extract icon if possible
    if ! extract_icon "$appimage_path" "$icon_path"; then
        # Use generic icon if extraction fails
        icon_path="application-x-executable"
        log_warning "Could not extract icon for $name, using generic icon"
    fi

    # Create desktop file
    cat > "$desktop_file" << EOF
[Desktop Entry]
Type=Application
Name=$name
Comment=AppImage application
Exec="$appimage_path" %U
Icon=$icon_path
Categories=AppImage;
Terminal=false
StartupNotify=true
X-AppImage-Path=$appimage_path
X-Created-By=aegix-appimage
EOF

    # Make desktop file executable (some systems require this)
    chmod +x "$desktop_file" 2>/dev/null || true

    log_success "Created desktop entry for $name"
}

# Scan for AppImages
scan_appimages() {
    log_info "Scanning for AppImages..."

    local found_count=0
    local processed_count=0

    # Clear old registry
    echo '{"appimages": [], "last_scan": "'$(date -Iseconds)'"}' > "$REGISTRY_FILE"

    for dir in "${APPIMAGE_DIRS[@]}"; do
        [[ -d "$dir" ]] || continue

        log_info "Scanning $dir..."

        # Find all AppImages (both .AppImage and .appimage extensions)
        while IFS= read -r -d '' appimage; do
            found_count=$((found_count + 1))

            # Get base name for the app
            local basename=$(basename "$appimage")
            local name="${basename%.*}"  # Remove extension

            # Clean up name (remove version numbers, etc.)
            name=$(echo "$name" | sed 's/[-_][0-9].*$//' | sed 's/[_-]/ /g')

            # Capitalize first letter of each word
            name=$(echo "$name" | sed 's/\b\(.\)/\u\1/g')

            # Generate unique desktop file name
            local desktop_filename="aegix-$(basename "$appimage" | tr ' ' '-' | tr '[:upper:]' '[:lower:]').desktop"
            local desktop_file="$DESKTOP_DIR/$desktop_filename"

            # Generate icon path
            local icon_filename="aegix-$(basename "$appimage" .AppImage | tr ' ' '-' | tr '[:upper:]' '[:lower:]').png"
            local icon_path="$ICON_DIR/$icon_filename"

            log_info "Processing: $name"

            # Generate desktop file
            generate_desktop_file "$appimage" "$name" "$desktop_file" "$icon_path"

            # Add to registry
            jq --arg name "$name" \
               --arg path "$appimage" \
               --arg desktop "$desktop_file" \
               --arg icon "$icon_path" \
               '.appimages += [{
                   "name": $name,
                   "path": $path,
                   "desktop_file": $desktop,
                   "icon": $icon,
                   "added": "'$(date -Iseconds)'"
               }]' "$REGISTRY_FILE" > "$REGISTRY_FILE.tmp" && mv "$REGISTRY_FILE.tmp" "$REGISTRY_FILE"

            processed_count=$((processed_count + 1))

        done < <(find "$dir" -type f \( -iname "*.appimage" -o -iname "*.AppImage" \) -print0 2>/dev/null)
    done

    # Update desktop database
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    fi

    log_success "Scan complete! Found $found_count AppImages, processed $processed_count"
    log_info "Desktop entries created in $DESKTOP_DIR"
}

# List registered AppImages
list_appimages() {
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        log_warning "No AppImages registered. Run 'aegix-appimage scan' first."
        return 1
    fi

    echo -e "${GREEN}Registered AppImages:${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    jq -r '.appimages[] | "• \(.name)\n  Path: \(.path)\n  Desktop: \(.desktop_file)"' "$REGISTRY_FILE" 2>/dev/null || {
        log_error "Failed to read registry"
        return 1
    }
}

# Clean up orphaned desktop files
clean_desktop_files() {
    log_info "Cleaning orphaned desktop entries..."

    local cleaned_count=0

    # Find all desktop files created by us
    for desktop_file in "$DESKTOP_DIR"/aegix-*.desktop; do
        [[ -f "$desktop_file" ]] || continue

        # Check if it was created by us
        if grep -q "X-Created-By=aegix-appimage" "$desktop_file" 2>/dev/null; then
            # Extract AppImage path
            local appimage_path=$(grep "X-AppImage-Path=" "$desktop_file" | cut -d= -f2)

            # If AppImage doesn't exist, remove desktop file
            if [[ ! -f "$appimage_path" ]]; then
                log_info "Removing orphaned entry: $(basename "$desktop_file")"
                rm -f "$desktop_file"
                cleaned_count=$((cleaned_count + 1))
            fi
        fi
    done

    log_success "Cleaned $cleaned_count orphaned entries"
}

# Generate shell aliases
generate_aliases() {
    local alias_file="$HOME/.config/zsh/appimage-aliases"

    log_info "Generating shell aliases..."

    {
        echo "# AppImage aliases - generated by aegix-appimage"
        echo "# Generated: $(date)"
        echo ""

        if [[ -f "$REGISTRY_FILE" ]]; then
            jq -r '.appimages[] | "alias \(.name | ascii_downcase | gsub(" "; ""))=\"\(.path)\""' "$REGISTRY_FILE" 2>/dev/null
        fi
    } > "$alias_file"

    log_success "Aliases generated in $alias_file"
    log_info "Add 'source $alias_file' to your .zshrc to use them"
}

# Show help
show_help() {
    cat << EOF
Aegix AppImage Manager

Usage: $(basename "$0") [COMMAND]

Commands:
    scan        Scan for AppImages and create desktop entries
    list        List all registered AppImages
    clean       Remove orphaned desktop entries
    aliases     Generate shell aliases for AppImages
    help        Show this help message

Examples:
    $(basename "$0") scan       # Discover and register all AppImages
    $(basename "$0") list       # Show registered AppImages
    $(basename "$0") clean      # Clean up old entries
    $(basename "$0") aliases    # Generate shell aliases

AppImage directories scanned:
$(printf '    • %s\n' "${APPIMAGE_DIRS[@]}")

Desktop entries created in:
    $DESKTOP_DIR

Registry stored at:
    $REGISTRY_FILE
EOF
}

# Main command handling
case "${1:-scan}" in
    scan)
        scan_appimages
        ;;
    list)
        list_appimages
        ;;
    clean)
        clean_desktop_files
        ;;
    aliases)
        generate_aliases
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac