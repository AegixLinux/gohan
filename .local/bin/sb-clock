#!/bin/sh

clock=$(date '+%I')

case "$clock" in
        "00") icon="🕛" ;;
        "01") icon="🕐" ;;
        "02") icon="🕑" ;;
        "03") icon="🕒" ;;
        "04") icon="🕓" ;;
        "05") icon="🕔" ;;
        "06") icon="🕕" ;;
        "07") icon="🕖" ;;
        "08") icon="🕗" ;;
        "09") icon="🕘" ;;
        "10") icon="🕙" ;;
        "11") icon="🕚" ;;
        "12") icon="🕛" ;;
esac

case $BLOCK_BUTTON in
        1) # Left click - popup calendar
           yad --calendar --undecorated --fixed --close-on-unfocus \
               --no-buttons --title="Calendar" \
               --geometry=250x200+100+30 2>/dev/null &
           ;;
        2) # Middle click - show current timezone
           tz=$(readlink /etc/localtime | sed 's|/usr/share/zoneinfo/||')
           notify-send "🌍 Current Timezone" "$tz\n\nLocal: $(date '+%H:%M %Z')\nUTC: $(date -u '+%H:%M UTC')"
           ;;
        3) # Right click - timezone switcher
           setsid -f dmenu-tz-switcher
           ;;
        6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Display the date and time in 24-hour format
date "+%Y-%m-%d %a %H:%M"
